---
title: Théâtre de l'eau qui dort — « Le Premier Homme » d'après Albert Camus
description: "Compagnie de théâtre — Le Premier Homme, d'après Albert Camus, adaptation et mise en scène Patrick Roldez, avec David Seigneur. Au Festival OFF d'Avignon 2026 (Le Petit Louvre). Dossier de presse et contact diffusion pour programmateurs."
canonical: ""
ogTitle: "« Le Premier Homme » d'après Albert Camus — Théâtre de l'eau qui dort"
ogDescription: "Adaptation et mise en scène Patrick Roldez, avec David Seigneur. Au Festival OFF d'Avignon 2026, Le Petit Louvre, du 4 au 25 juillet à 21h05."
permalink: index.html
layout: false
---
{% extends "base.njk" %}

{% block extraMeta %}
  <meta name="keywords" content="Le Premier Homme, Albert Camus, compagnie de théâtre, seul en scène, festival OFF Avignon, diffusion spectacle vivant, théâtre, programmation, centre culturel, dossier de presse" />
  <meta name="author" content="Théâtre de l'eau qui dort" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Le Premier Homme — Théâtre de l'eau qui dort" />
  <meta name="twitter:description" content="D'après Albert Camus. Festival OFF d'Avignon 2026, Le Petit Louvre, du 4 au 25 juillet à 21h05." />
  <meta name="twitter:image" content="{{ site.url }}/assets/img/affiche-le-premier-homme.jpg" />
{% endblock %}

{% block jsonld %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "PerformingGroup",
    "@id": "{{ site.url }}/#compagnie",
    "name": "Théâtre de l'eau qui dort",
    "alternateName": "Cie l'eau qui dort",
    "description": "Compagnie de théâtre dirigée par Patrick Roldez, défendant un théâtre exigeant proposé à tous : Camus, Mamet, Koltès, Molière, Dario Fo. Spectacle en tournée : Le Premier Homme, d'après Albert Camus, avec David Seigneur.",
    "url": "{{ site.url }}/",
    "logo": "{{ site.url }}/assets/img/logo.svg",
    "image": "{{ site.url }}/assets/img/affiche-le-premier-homme.jpg",
    "genre": ["Théâtre", "Spectacle vivant"],
    "email": "{{ reglages.email }}",
    "telephone": "{{ reglages.telephoneLien }}",
    "areaServed": "FR",
    "contactPoint": {
      "@type": "ContactPoint",
      "contactType": "Diffusion / booking",
      "email": "{{ reglages.email }}",
      "telephone": "{{ reglages.telephoneLien }}",
      "availableLanguage": ["French"]
    }
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Théâtre de l'eau qui dort",
    "url": "{{ site.url }}/",
    "inLanguage": "fr-FR"
  }
  </script>
{% endblock %}

{% block content %}
    <!-- ==================== HERO ==================== -->
    <section class="hero">
      <div class="hero__media">
        <img src="{{ accueil.hero.image }}" alt="{{ accueil.hero.imageAlt }}" width="1600" height="1000" fetchpriority="high" />
      </div>
      <div class="container">
        <div class="hero__inner">
          <span class="eyebrow">{{ accueil.hero.surtitre }}</span>
          <h1>{{ accueil.hero.titre }}</h1>
          <p class="lead">{{ accueil.hero.accroche }}</p>
          <div class="hero__actions">
            <a class="btn btn--primary" href="spectacle.html">Découvrir le spectacle <span class="btn__arrow">→</span></a>
            <a class="btn btn--ghost" href="{{ reglages.dossierPresse }}" download>Télécharger le dossier de presse</a>
          </div>
          <dl class="hero__meta">
            {%- for m in accueil.hero.metas %}
            <div><dt>{{ m.label }}</dt><dd>{{ m.valeur }}</dd></div>
            {%- endfor %}
          </dl>
        </div>
      </div>
    </section>

    <!-- ==================== LA TROUPE ==================== -->
    <section>
      <div class="container split">
        <div class="reveal">
          <span class="eyebrow">{{ accueil.troupe.surtitre }}</span>
          <h2>{{ accueil.troupe.titre }}</h2>
          <div class="mt-2">{{ accueil.troupe.texte | md | safe }}</div>
          <a class="btn btn--ghost mt-2" href="equipe.html">Rencontrer l'équipe <span class="btn__arrow">→</span></a>
        </div>
        <div class="reveal">
          <div class="feature-img">
            <img src="{{ accueil.troupe.image }}" alt="{{ accueil.troupe.imageAlt }}" width="800" height="1074" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    <!-- ==================== PRESSE (citations) ==================== -->
    <section style="background:var(--ink-2); border-block:1px solid var(--line);">
      <div class="container">
        <div class="section-head text-center" style="margin-inline:auto;">
          <span class="eyebrow">{{ accueil.citations.surtitre }}</span>
          <h2>{{ accueil.citations.titre }}</h2>
        </div>
        <div class="grid grid--2">
          {%- for c in accueil.citations.liste %}
          <div class="quote reveal">
            <blockquote>{{ c.texte | safe }}</blockquote>
            <cite>{{ c.media }} <span>{{ c.source }}</span></cite>
          </div>
          {%- endfor %}
        </div>
        <div class="text-center mt-3">
          <a class="btn btn--ghost" href="autres-spectacles.html">Toute la revue de presse <span class="btn__arrow">→</span></a>
        </div>
      </div>
    </section>

    <!-- ==================== AGENDA ==================== -->
    <section>
      <div class="container">
        <div class="section-head">
          <span class="eyebrow">{{ accueil.dates.surtitre }}</span>
          <h2>{{ accueil.dates.titre }}</h2>
        </div>
        {%- for d in accueil.dates.liste %}
        <div class="date-row">
          <div class="date-row__date"><span class="day">{{ d.jour }}</span><span class="month">{{ d.mois }}</span> <span class="year">{{ d.annee }}</span></div>
          <div class="date-row__info"><h3>{{ d.lieu }}</h3><p>{{ d.details }}</p></div>
          <span class="date-row__status status--{{ d.statutType }}">{{ d.statut }}</span>
        </div>
        {%- endfor %}
        <div class="mt-3"><a class="btn btn--ghost" href="spectacle.html">Découvrir le spectacle <span class="btn__arrow">→</span></a></div>
      </div>
    </section>

    <!-- ==================== HISTOIRE DE LA TROUPE ==================== -->
    <section style="background:var(--ink-2); border-block:1px solid var(--line);">
      <div class="container container--narrow">
        <div class="section-head"><span class="eyebrow">{{ accueil.histoire.surtitre }}</span><h2>{{ accueil.histoire.titre }}</h2></div>
        {{ accueil.histoire.texte | md | safe }}
      </div>
    </section>

    <!-- ==================== PRESSE / DOSSIER ==================== -->
    <section>
      <div class="container">
        <div class="pro-banner reveal">
          <div class="split">
            <div>
              <span class="eyebrow">Professionnels &amp; presse</span>
              <h2>Vous programmez ?<br />Tout est ici.</h2>
              <p class="mt-2">Directeurs de centres culturels, de festivals, responsables de programmation, journalistes : téléchargez le dossier de presse et contactez-nous directement.</p>
              <div class="hero__actions mt-3">
                <a class="btn btn--primary" href="presse.html">Espace presse <span class="btn__arrow">→</span></a>
                <a class="btn btn--ghost" href="contact.html">Contacter la compagnie</a>
              </div>
            </div>
            <div>
              <a class="download-card mb-2" href="{{ reglages.dossierPresse }}" download>
                <span class="download-card__icon" aria-hidden="true">⤓</span>
                <span class="download-card__body"><h3>Dossier de presse — Le Premier Homme</h3><p class="download-card__meta">PDF · 665 Ko</p></span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ==================== FAQ (optimisée GEO) ==================== -->
    <section style="background:var(--ink-2); border-top:1px solid var(--line);">
      <div class="container container--narrow">
        <div class="section-head"><span class="eyebrow">Questions fréquentes</span><h2>Informations diffusion</h2></div>
        <div class="datalist" style="border-top:0;">
          {%- for f in accueil.faq %}
          <details style="{% if not loop.last %}border-bottom:1px solid var(--line); {% endif %}padding:1.2rem 0;">
            <summary style="cursor:pointer; font-family:var(--serif); font-size:1.3rem; color:var(--paper);">{{ f.question }}</summary>
            <div class="mt-2">{{ f.reponse | md | safe }}</div>
          </details>
          {%- endfor %}
        </div>
      </div>
    </section>

    <!-- ==================== CTA BAND ==================== -->
    <section class="cta-band">
      <div class="container">
        <span class="eyebrow" style="margin-inline:auto; display:block; width:fit-content;">Diffusion</span>
        <h2>Accueillez le spectacle dans votre saison</h2>
        <p>Parlons de votre programmation. L'équipe vous répond rapidement et vous transmet tous les éléments nécessaires.</p>
        <a class="btn btn--primary" href="contact.html">Prendre contact <span class="btn__arrow">→</span></a>
      </div>
    </section>
{% endblock %}
